# AI CMO - Production Environment Configuration
# ⚠️  CRITICAL: Use strong passwords and keep this file secure!

# ============================================
# Database Configuration
# ============================================
DB_USER=ai_cmo_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
DB_NAME=ai_cmo_prod

MONGODB_URI=mongodb://ai_cmo_prod:CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN@mongodb:27017/ai_cmo_prod?authSource=admin
REDIS_URL=redis://redis:6379

# ============================================
# Authentication
# ============================================
# ⚠️  Use a strong random JWT secret (32+ characters)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_MIN_32_CHARACTERS_LONG
JWT_EXPIRES_IN=7d

# ============================================
# Application URLs
# ============================================
# Replace with your actual domain
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com
PORT=3001

# ============================================
# AI API Keys (Required for production)
# ============================================
CLAUDE_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Email Configuration (Required for production)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# File Upload Settings
# ============================================
MAX_FILE_SIZE=20971520
UPLOAD_DIR=./uploads

# ============================================
# Logging
# ============================================
LOG_LEVEL=warn

# ============================================
# Security
# ============================================
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mengo

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API
API_PORT=3001
API_URL=http://localhost:3001

# Frontend
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ML Service
ML_PORT=5000
ML_API_URL=http://localhost:5000

# AWS (if using)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Monitoring
SENTRY_DSN=
LOG_LEVEL=debug

# Feature Flags
FEATURE_NEW_DASHBOARD=false

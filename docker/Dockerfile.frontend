# AI CMO Frontend Dockerfile
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* ./
RUN npm ci

# Copy Next.js config
COPY next.config.js ./
COPY next.config.ts ./

# Expose port
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev"]

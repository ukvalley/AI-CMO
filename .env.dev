# Mengo - Development Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
DB_USER=mengo_dev
DB_PASSWORD=dev_secure_password_change_me
DB_NAME=mengo_dev

MONGODB_URI=mongodb://mengo_dev:dev_secure_password_change_me@mongodb:27017/mengo_dev?authSource=admin
REDIS_URL=redis://redis:6379

# ============================================
# Authentication
# ============================================
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# Application URLs
# ============================================
FRONTEND_URL=http://localhost:3100
BACKEND_URL=http://localhost:3101
PORT=3101

# ============================================
# AI API Keys (Optional for development)
# ============================================
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ============================================
# File Upload Settings
# ============================================
MAX_FILE_SIZE=20971520
UPLOAD_DIR=./uploads

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
